# Copy to .env and fill in. NEVER commit a real .env (it is gitignored).

# Bearer token clients must send to reach the MCP endpoint. Generate one with:
#   openssl rand -hex 32
# Leave empty for local dev to disable auth (NOT recommended for any network deploy).
MCP_TOKEN=

# Base URL of your FreshRSS instance (no trailing /api/...).
# Examples: http://localhost:8080  |  https://rss.example.com
FRESHRSS_URL=https://rss.example.com

# FreshRSS username.
FRESHRSS_USER=alice

# The per-user API password (Settings -> Profile -> "API password" in FreshRSS).
# This is NOT your web login password. The GReader API must also be enabled
# under Settings -> Authentication -> "Allow API access".
FRESHRSS_API_PASSWORD=

# Optional.
PORT=8080
FRESHRSS_TIMEOUT=30
